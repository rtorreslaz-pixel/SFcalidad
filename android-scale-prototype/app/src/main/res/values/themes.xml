<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema claro con la identidad San Fernando. Material 3 propaga estos colores a
         botones, campos de texto, spinners, checkboxes y demás controles de la app. -->
    <style name="Theme.BasculaRangerTest" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sf_blue</item>
        <item name="colorOnPrimary">@color/sf_white</item>
        <item name="colorPrimaryContainer">@color/sf_blue_container</item>
        <item name="colorOnPrimaryContainer">@color/sf_blue_deep</item>
        <item name="colorSecondary">@color/sf_blue_deep</item>
        <item name="colorOnSecondary">@color/sf_white</item>
        <item name="colorSecondaryContainer">@color/sf_cyan</item>
        <item name="colorOnSecondaryContainer">@color/sf_blue_deep</item>
        <item name="colorError">@color/sf_red</item>
        <item name="android:statusBarColor">@color/sf_blue_deep</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>
</resources>
