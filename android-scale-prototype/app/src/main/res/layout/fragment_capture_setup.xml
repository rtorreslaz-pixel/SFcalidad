<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_capture_setup"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_plantel"
            android:textStyle="bold"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spinnerPlantel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/editGalpon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_galpon"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/editCorral"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_corral"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_categoria"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <RadioGroup
            android:id="@+id/radioGroupCategoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/radioMacho"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/categoria_macho"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radioHembra"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/categoria_hembra" />

            <RadioButton
                android:id="@+id/radioMediano"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/categoria_mediano" />
        </RadioGroup>

        <Button
            android:id="@+id/buttonStartCapture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_start_capture" />

        <ProgressBar
            android:id="@+id/progressSetup"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textSetupError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
