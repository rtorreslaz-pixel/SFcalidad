<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_muestreos_dia"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textResumen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/containerMuestreos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <TextView
        android:id="@+id/textVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/muestreos_vacio"
        android:gravity="center"
        android:textColor="#666666"
        android:layout_marginTop="24dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/buttonSync"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/action_sync_pendientes" />

    <Button
        android:id="@+id/buttonVolver"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/action_volver" />

</LinearLayout>
