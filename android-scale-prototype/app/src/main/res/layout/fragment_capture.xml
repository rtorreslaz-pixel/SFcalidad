<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/textSelectionHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textChangeSelection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_change_selection"
            android:textColor="@color/sf_blue"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <TextView
        android:id="@+id/textCaptureSubHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/textPendingBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/textCaptureStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textCaptureWeight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/weight_placeholder"
        android:textSize="56sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <Switch
        android:id="@+id/switchEvaluarCalidad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/switch_evaluar_calidad"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:id="@+id/layoutCalidad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_pododermatitis"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />

        <RadioGroup
            android:id="@+id/radioGroupPododermatitis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioPodoSano"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:checked="true"
                android:text="@string/grado_sano" />

            <RadioButton
                android:id="@+id/radioPodoLeve"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:text="@string/grado_leve" />

            <RadioButton
                android:id="@+id/radioPodoGrave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:text="@string/grado_grave" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_rasguno"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />

        <RadioGroup
            android:id="@+id/radioGroupRasguno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioRasgSano"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:checked="true"
                android:text="@string/grado_sano" />

            <RadioButton
                android:id="@+id/radioRasgLeve"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:text="@string/grado_leve" />

            <RadioButton
                android:id="@+id/radioRasgGrave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:text="@string/grado_grave" />
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_pigmentacion"
                android:textSize="11sp"
                android:layout_marginEnd="8dp" />

            <Spinner
                android:id="@+id/spinnerPigmentacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/buttonRegisterAve"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:enabled="false"
        android:text="@string/action_register_ave"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/textLastRegistered"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textSize="13sp"
        android:gravity="center" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/textOpenDiagnostic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/action_open_diagnostic"
        android:textColor="@color/sf_blue"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
