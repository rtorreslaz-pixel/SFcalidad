// Prisma schema - App de Inspección de Calidad Avícola

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  VERIFICADOR
  SUPERVISOR
  JEFE
  COMERCIAL
}

enum SexoAve {
  MACHO
  HEMBRA
}

enum CategoriaLesion {
  ALMOHADILLAS
  RASGUNOS
}

enum EstadoInspeccion {
  BORRADOR
  COMPLETA
}

enum GradoHematoma {
  GRADO1
  GRADO2
  GRADO3
}

enum UbicacionHematoma {
  ALA
  ESPINAZO
  PECHUGA
  PIERNA
}

enum CategoriaAve {
  MACHO
  HEMBRA
  MEDIANO
}

enum TipoMuestreo {
  PREVENTA
  CALIDAD // reservado para una fase futura, no usado todavía
}

model User {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  role         Role     @default(VERIFICADOR)
  activo       Boolean  @default(true)
  apiToken     String?  @unique
  createdAt    DateTime @default(now())

  jornadas              Jornada[]
  inspecciones          Inspeccion[]
  registrosPesoPreventa RegistroPesoPreventa[]
  liveWeightReading     LiveWeightReading?
}

model Cliente {
  id     String @id @default(cuid())
  nombre String @unique

  planteles    Plantel[]
  jornadas     Jornada[]
  inspecciones Inspeccion[]
}

model Plantel {
  id             String  @id @default(cuid())
  codigo         String  @unique
  nombre         String?
  zona           String?
  subZona        String?
  tipoPlantel    String?
  zonaEvaluacion String?

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  inspecciones          Inspeccion[]
  registrosPesoPreventa RegistroPesoPreventa[]
}

model TipoDefecto {
  id        String  @id @default(cuid())
  nombre    String  @unique
  categoria String?
  orden     Int     @default(0)
  principal Boolean @default(false)

  registros DefectoRegistro[]
}

model Jornada {
  id     String   @id @default(cuid())
  fecha  DateTime
  anio   Int
  mes    Int
  semana Int

  clienteId     String
  cliente       Cliente @relation(fields: [clienteId], references: [id])
  verificadorId String
  verificador   User    @relation(fields: [verificadorId], references: [id])

  saldos       SaldoDiaAnterior[]
  inspecciones Inspeccion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SaldoDiaAnterior {
  id        String  @id @default(cuid())
  jornadaId String
  jornada   Jornada @relation(fields: [jornadaId], references: [id], onDelete: Cascade)

  sexo SexoAve

  // Saldo total que dejó el cliente
  unidades Int?
  jabas    Int?
  kg       Float?

  // De ese saldo, lo que el cliente considera selección
  unidadesSeleccion Int?
  jabasSeleccion    Int?
  kgSeleccion       Float?

  // Lo que quedó sin vender tras el beneficiado del saldo
  unidadesRemanente Int?
  jabasRemanente    Int?
  kgRemanente       Float?

  @@unique([jornadaId, sexo])
}

model Inspeccion {
  id String @id @default(cuid())

  jornadaId String?
  jornada   Jornada? @relation(fields: [jornadaId], references: [id])

  // Legacy fields kept for existing rows
  fecha          DateTime?
  anio           Int?
  mes            Int?
  semana         Int?
  campania       String?
  clienteId      String?
  cliente        Cliente?  @relation(fields: [clienteId], references: [id])
  verificadorId  String?
  verificador    User?     @relation(fields: [verificadorId], references: [id])
  metaPorcentaje Float     @default(0.6)

  plantelId String?
  plantel   Plantel? @relation(fields: [plantelId], references: [id])

  galpon   String?
  corral   String?
  sexo     SexoAve?
  jabas    Int?
  cantidad Int      @default(0)

  promVivo        Float?
  promBeneficiado Float?

  nroGuia       String?
  complex       String?
  observaciones String?

  tempPlataforma      Float?
  tempPlataformaVacia Float?
  tempCamion          Float?
  tempAves            Float?
  densidad            Float?

  hematomasCon Int?
  hematomasSin Int?

  pigNivel0 Int @default(0)
  pigNivel1 Int @default(0)
  pigNivel2 Int @default(0)
  pigNivel3 Int @default(0)
  pigNivel4 Int @default(0)
  pigNivel5 Int @default(0)
  pigNivel6 Int @default(0)
  pigNivel7 Int @default(0)

  mermaAlaKg    Float?
  mermaPiernaKg Float?

  estado     EstadoInspeccion @default(BORRADOR)
  pasoActual Int              @default(1)

  // true cuando el registro solo trae datos de pododermatitis/rasguños o pigmentación
  // (sin censo de selección/merma); se excluye de esos ratios para no diluirlos.
  soloLesionPigmentacion Boolean @default(false)

  defectos           DefectoRegistro[]
  fotos              Foto[]
  evaluacionesLesion EvaluacionLesion[]
  hematomaDetalles   HematomaDetalle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DefectoRegistro {
  id String @id @default(cuid())

  inspeccionId String
  inspeccion   Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  tipoDefectoId String
  tipoDefecto   TipoDefecto @relation(fields: [tipoDefectoId], references: [id])

  unidades Int   @default(0)
  kg       Float @default(0)

  @@unique([inspeccionId, tipoDefectoId])
}

model Foto {
  id String @id @default(cuid())

  inspeccionId String
  inspeccion   Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  path        String
  descripcion String?
  latitud     Float?
  longitud    Float?

  createdAt DateTime @default(now())
}

model HematomaDetalle {
  id String @id @default(cuid())

  inspeccionId String
  inspeccion   Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  grado     GradoHematoma
  ubicacion UbicacionHematoma

  cantidad Int @default(0)

  @@unique([inspeccionId, grado, ubicacion])
}

model EvaluacionLesion {
  id String @id @default(cuid())

  inspeccionId String
  inspeccion   Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  categoria CategoriaLesion
  sexo      SexoAve

  muestra   Int @default(0)
  sinLesion Int @default(0)
  leve      Int @default(0)
  grave     Int @default(0)

  @@unique([inspeccionId, categoria, sexo])
}

model RegistroPesoPreventa {
  // Id generado por el cliente Android (UUID v4) ANTES de sincronizar, para que
  // reintentos de red produzcan upserts idempotentes en vez de duplicados.
  // NO cambiar a @default(cuid()) -- ver POST /api/mobile/registros.
  id String @id

  plantelId String
  plantel   Plantel @relation(fields: [plantelId], references: [id])

  campania  String?
  galpon    String
  corral    String
  categoria CategoriaAve

  numeroAve  Int
  pesoGramos Float
  fechaHora  DateTime // momento de captura en campo (hora del celular), no de sync

  // Plantel-Campaña-Galpón-Categoría-Corral, mismo formato que Inspeccion.complex,
  // para cruzar peso de preventa contra evaluaciones de calidad del mismo lote.
  complex String?

  tipoMuestreo TipoMuestreo @default(PREVENTA)

  // Criterios de calidad evaluados opcionalmente sobre la misma ave pesada, en la misma
  // pantalla de captura (no todas las aves se evalúan -- el chequeo de calidad toma más
  // tiempo que pesar sola, así que el verificador lo activa solo para una sub-muestra).
  // Mismos criterios que Inspeccion.{hematomasCon/Sin, defectos, evaluacionesLesion,
  // pigNivel*} pero a nivel de ave individual en granja, para poder comparar contra el
  // censo de calidad de cliente lote por lote.
  // Metadatos del lote al momento de la pesada
  edad          Int?    // días de vida del lote
  linea         String? // línea genética (ej. Ross, Cobb)
  lote          String? // J (Joven) / A (Adulto)
  nAvesPorPesada Int?   // N° aves pesadas juntas por lectura de báscula

  tieneHematoma         Boolean?
  tieneDefectoSeleccion Boolean?
  gradoPododermatitis   Int? // 0 sin lesión, 1 leve, 2 grave (grave = Grado 2, igual que EvaluacionLesion.grave)
  gradoRasguno          Int? // 0 sin lesión, 1 leve, 2 grave
  pigmentacion          Int? // 0-7

  verificadorId String
  verificador   User @relation(fields: [verificadorId], references: [id])

  syncedAt  DateTime @default(now()) // momento en que el servidor lo recibió
  createdAt DateTime @default(now())

  @@index([plantelId, galpon, corral, categoria])
  @@index([verificadorId, fechaHora])
}

// Tabla de pesos estándar por raza, sexo y edad. Se incluye en GET /api/mobile/catalogos
// para que la app compare el peso en vivo contra el estándar sin llamadas adicionales.
// Poblar con los datos de la hoja STD del Excel del cliente.
model PesoEstandar {
  id         String  @id @default(cuid())
  linea      String  // "Ross", "Cobb", "Hubbard", etc.
  sexo       SexoAve // MACHO | HEMBRA
  edadDias   Int
  pesoGramos Float

  @@unique([linea, sexo, edadDias])
  @@index([linea, sexo])
}

// Última lectura de la báscula por verificador, sobrescrita en cada lectura
// (no es historial -- el historial real son los RegistroPesoPreventa). Alimenta
// el panel "Peso en vivo" del dashboard.
model LiveWeightReading {
  verificadorId String @id
  verificador   User   @relation(fields: [verificadorId], references: [id])

  pesoGramos Float

  plantelCodigo String?
  campania      String?
  galpon        String?
  corral        String?
  categoria     CategoriaAve?
  complex       String?

  updatedAt DateTime @updatedAt
}
