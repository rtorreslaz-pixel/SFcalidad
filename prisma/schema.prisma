// Prisma schema - App de Inspección de Calidad Avícola

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  VERIFICADOR
  SUPERVISOR
}

enum Sexo {
  MACHO
  HEMBRA
  MIXTO
}

enum CategoriaAve {
  MACHO
  HEMBRA
  MEDIANO
}

enum TipoMuestreo {
  PREVENTA
  CALIDAD // reservado para una fase futura, no usado todavía
}

model User {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  role         Role     @default(VERIFICADOR)
  activo       Boolean  @default(true)
  apiToken     String?  @unique
  createdAt    DateTime @default(now())

  inspecciones           Inspeccion[]
  registrosPesoPreventa  RegistroPesoPreventa[]
}

model Cliente {
  id     String @id @default(cuid())
  nombre String @unique

  planteles    Plantel[]
  inspecciones Inspeccion[]
}

model Plantel {
  id             String  @id @default(cuid())
  codigo         String  @unique
  nombre         String?
  zona           String?
  subZona        String?
  tipoPlantel    String?
  zonaEvaluacion String?

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  inspecciones          Inspeccion[]
  registrosPesoPreventa RegistroPesoPreventa[]
}

model TipoDefecto {
  id        String @id @default(cuid())
  nombre    String @unique
  categoria String?
  orden     Int    @default(0)

  registros DefectoRegistro[]
}

model Inspeccion {
  id       String   @id @default(cuid())
  fecha    DateTime
  anio     Int
  mes      Int
  semana   Int

  campania String?
  nroGuia  String?

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  plantelId String?
  plantel   Plantel? @relation(fields: [plantelId], references: [id])

  galpon String?
  sexo   Sexo?

  cantidad      Int
  pesoVivo      Float?
  pesoBeneficio Float?
  metaPorcentaje Float @default(0.6)

  observaciones String?

  verificadorId String
  verificador   User   @relation(fields: [verificadorId], references: [id])

  defectos DefectoRegistro[]
  fotos    Foto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DefectoRegistro {
  id String @id @default(cuid())

  inspeccionId String
  inspeccion   Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  tipoDefectoId String
  tipoDefecto   TipoDefecto @relation(fields: [tipoDefectoId], references: [id])

  unidades Int   @default(0)
  kg       Float @default(0)

  @@unique([inspeccionId, tipoDefectoId])
}

model Foto {
  id String @id @default(cuid())

  inspeccionId String
  inspeccion   Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  path        String
  descripcion String?
  latitud     Float?
  longitud    Float?

  createdAt DateTime @default(now())
}

model RegistroPesoPreventa {
  // Id generado por el cliente Android (UUID v4) ANTES de sincronizar, para que
  // reintentos de red produzcan upserts idempotentes en vez de duplicados.
  // NO cambiar a @default(cuid()) -- ver POST /api/mobile/registros.
  id String @id

  plantelId String
  plantel   Plantel @relation(fields: [plantelId], references: [id])

  galpon    String
  corral    String
  categoria CategoriaAve

  numeroAve  Int
  pesoGramos Float
  fechaHora  DateTime // momento de captura en campo (hora del celular), no de sync

  tipoMuestreo TipoMuestreo @default(PREVENTA)

  verificadorId String
  verificador   User @relation(fields: [verificadorId], references: [id])

  syncedAt  DateTime @default(now()) // momento en que el servidor lo recibió
  createdAt DateTime @default(now())

  @@index([plantelId, galpon, corral, categoria])
  @@index([verificadorId, fechaHora])
}
