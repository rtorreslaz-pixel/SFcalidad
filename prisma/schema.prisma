// Prisma schema - App de Inspección de Calidad Avícola

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  VERIFICADOR
  SUPERVISOR
  JEFE
}

enum SexoAve {
  MACHO
  HEMBRA
}

enum CategoriaLesion {
  ALMOHADILLAS
  RASGUNOS
}

enum EstadoInspeccion {
  BORRADOR
  COMPLETA
}

model User {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  role         Role     @default(VERIFICADOR)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())

  jornadas     Jornada[]
  inspecciones Inspeccion[]
}

model Cliente {
  id     String @id @default(cuid())
  nombre String @unique

  planteles    Plantel[]
  jornadas     Jornada[]
  inspecciones Inspeccion[]
}

model Plantel {
  id             String  @id @default(cuid())
  codigo         String  @unique
  nombre         String?
  zona           String?
  subZona        String?
  tipoPlantel    String?
  zonaEvaluacion String?

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  inspecciones Inspeccion[]
}

model TipoDefecto {
  id        String  @id @default(cuid())
  nombre    String  @unique
  categoria String?
  orden     Int     @default(0)
  principal Boolean @default(false)

  registros DefectoRegistro[]
}

model Jornada {
  id     String   @id @default(cuid())
  fecha  DateTime
  anio   Int
  mes    Int
  semana Int

  clienteId     String
  cliente       Cliente @relation(fields: [clienteId], references: [id])
  verificadorId String
  verificador   User    @relation(fields: [verificadorId], references: [id])

  saldos       SaldoDiaAnterior[]
  inspecciones Inspeccion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SaldoDiaAnterior {
  id        String  @id @default(cuid())
  jornadaId String
  jornada   Jornada @relation(fields: [jornadaId], references: [id], onDelete: Cascade)

  sexo SexoAve

  // Saldo total que dejó el cliente
  unidades Int?
  jabas    Int?
  kg       Float?

  // De ese saldo, lo que el cliente considera selección
  unidadesSeleccion Int?
  jabasSeleccion    Int?
  kgSeleccion       Float?

  // Lo que quedó sin vender tras el beneficiado del saldo
  unidadesRemanente Int?
  jabasRemanente    Int?
  kgRemanente       Float?

  @@unique([jornadaId, sexo])
}

model Inspeccion {
  id String @id @default(cuid())

  jornadaId String?
  jornada   Jornada? @relation(fields: [jornadaId], references: [id])

  // Legacy fields kept for existing rows
  fecha          DateTime?
  anio           Int?
  mes            Int?
  semana         Int?
  campania       String?
  clienteId      String?
  cliente        Cliente?  @relation(fields: [clienteId], references: [id])
  verificadorId  String?
  verificador    User?     @relation(fields: [verificadorId], references: [id])
  metaPorcentaje Float     @default(0.6)

  plantelId String?
  plantel   Plantel? @relation(fields: [plantelId], references: [id])

  galpon   String?
  sexo     SexoAve?
  jabas    Int?
  cantidad Int      @default(0)

  promVivo        Float?
  promBeneficiado Float?

  nroGuia       String?
  complex       String?
  observaciones String?

  tempPlataforma Float?
  tempCamion     Float?
  tempAves       Float?

  hematomasCon Int?
  hematomasSin Int?

  pigNivel0 Int @default(0)
  pigNivel1 Int @default(0)
  pigNivel2 Int @default(0)
  pigNivel3 Int @default(0)
  pigNivel4 Int @default(0)
  pigNivel5 Int @default(0)
  pigNivel6 Int @default(0)
  pigNivel7 Int @default(0)

  mermaAlaKg    Float?
  mermaPiernaKg Float?

  estado     EstadoInspeccion @default(BORRADOR)
  pasoActual Int              @default(1)

  defectos           DefectoRegistro[]
  fotos              Foto[]
  evaluacionesLesion EvaluacionLesion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DefectoRegistro {
  id String @id @default(cuid())

  inspeccionId String
  inspeccion   Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  tipoDefectoId String
  tipoDefecto   TipoDefecto @relation(fields: [tipoDefectoId], references: [id])

  unidades Int   @default(0)
  kg       Float @default(0)

  @@unique([inspeccionId, tipoDefectoId])
}

model Foto {
  id String @id @default(cuid())

  inspeccionId String
  inspeccion   Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  path        String
  descripcion String?
  latitud     Float?
  longitud    Float?

  createdAt DateTime @default(now())
}

model EvaluacionLesion {
  id String @id @default(cuid())

  inspeccionId String
  inspeccion   Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  categoria CategoriaLesion
  sexo      SexoAve

  muestra   Int @default(0)
  sinLesion Int @default(0)
  leve      Int @default(0)
  grave     Int @default(0)

  @@unique([inspeccionId, categoria, sexo])
}
